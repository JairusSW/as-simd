{
  "name": "as-simd",
  "version": "0.0.0",
  "description": "Drop-in AssemblyScript SIMD-compatible SWAR wrappers with transform support.",
  "main": "./transform/index.mjs",
  "types": "assembly/index.ts",
  "author": "Jairus Tanaka",
  "contributors": [],
  "license": "MIT",
  "scripts": {
    "test": "ast test",
    "test:integration:dropin": "node ./scripts/integration-dropin.mjs",
    "test:integration:simd-intent": "node ./scripts/integration-simd-intent.mjs",
    "prepublishOnly": "npm run build:transform && npm test && npm run test:integration:dropin && npm run test:integration:simd-intent",
    "fuzz": "ast fuzz",
    "fuzz:simd-parity": "ast fuzz assembly/__fuzz__/i8x8.fuzz.ts assembly/__fuzz__/i8x16.fuzz.ts assembly/__fuzz__/i8x16-swar.fuzz.ts assembly/__fuzz__/i16x4.fuzz.ts assembly/__fuzz__/i16x8.fuzz.ts assembly/__fuzz__/i16x8-swar.fuzz.ts assembly/__fuzz__/i32x2.fuzz.ts assembly/__fuzz__/i32x4.fuzz.ts assembly/__fuzz__/i32x4-swar.fuzz.ts assembly/__fuzz__/i64x2-swar.fuzz.ts assembly/__fuzz__/v64.fuzz.ts --mode simd",
    "test:fuzz": "ast test --fuzz",
    "build:test": "rm -rf ./build/ && asc assembly/test.ts --config none --transform ./transform/index.mjs --enable simd -o ./build/test.wasm",
    "build:transform": "node --check ./transform/index.mjs",
    "test:wasmtime": "wasmtime ./build/test.wasm",
    "bench": "./scripts/run-bench.sh",
    "format": "prettier -w .",
    "charts": "npm run charts:build && npm run charts:serve",
    "charts:build": "./scripts/build-charts.sh",
    "charts:serve": "serve ./charts"
  },
  "devDependencies": {
    "@assemblyscript/wasi-shim": "^0.1.0",
    "@types/node": "^25.6.0",
    "as-bench": "^0.0.0-alpha",
    "as-test": "1.0.12",
    "assemblyscript": "^0.28.17",
    "assemblyscript-prettier": "^3.0.4",
    "json-as": "^1.3.4",
    "serve": "^14.2.6",
    "as-simd": "file:."
  },
  "overrides": {
    "assemblyscript": "$assemblyscript"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JairusSW/as-simd.git"
  },
  "keywords": [
    "assemblyscript",
    "SIMD",
    "SSE",
    "AVX"
  ],
  "bugs": {
    "url": "https://github.com/JairusSW/as-simd/issues"
  },
  "homepage": "https://github.com/JairusSW/as-simd#readme",
  "type": "module",
  "files": [
    "assembly/index.ts",
    "assembly/v64/**/*.ts",
    "assembly/v128/**/*.ts",
    "assembly/scalar/**/*.ts",
    "transform/index.mjs",
    "globals.d.ts",
    "index.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "exports": {
    ".": {
      "types": "./assembly/index.ts",
      "default": "./transform/index.mjs"
    },
    "./sources": "./assembly/index.ts",
    "./assembly/v128/v128_swar": "./assembly/v128/v128_swar.ts",
    "./assembly/v128/i8x16_swar": "./assembly/v128/i8x16_swar.ts",
    "./assembly/v128/i16x8_swar": "./assembly/v128/i16x8_swar.ts",
    "./assembly/v128/i32x4_swar": "./assembly/v128/i32x4_swar.ts",
    "./assembly/v128/i32x4_swar_runtime": "./assembly/v128/i32x4_swar_runtime.ts",
    "./assembly/v128/i64x2_swar": "./assembly/v128/i64x2_swar.ts",
    "./transform": "./transform/index.mjs",
    "./globals": "./globals.d.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "@JairusSW:registry": "https://npm.pkg.github.com"
  }
}
