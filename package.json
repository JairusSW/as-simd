{
  "name": "as-simd",
  "version": "0.0.0",
  "description": "",
  "types": "assembly/index.ts",
  "author": "Jairus Tanaka",
  "contributors": [],
  "license": "MIT",
  "scripts": {
    "test": "ast test",
    "fuzz": "ast fuzz",
    "fuzz:simd-parity": "ast fuzz assembly/__fuzz__/i8x8.fuzz.ts assembly/__fuzz__/i8x16.fuzz.ts assembly/__fuzz__/i8x16-swar.fuzz.ts assembly/__fuzz__/i16x4.fuzz.ts assembly/__fuzz__/i16x8.fuzz.ts assembly/__fuzz__/i16x8-swar.fuzz.ts assembly/__fuzz__/i32x2.fuzz.ts assembly/__fuzz__/i32x4.fuzz.ts assembly/__fuzz__/i32x4-swar.fuzz.ts assembly/__fuzz__/i64x2-swar.fuzz.ts assembly/__fuzz__/v64.fuzz.ts --mode simd",
    "test:fuzz": "ast test --fuzz",
    "build:test": "rm -rf ./build/ && asc assembly/test.ts -o ./build/test.wasm --config ./node_modules/@assemblyscript/wasi-shim/asconfig.json",
    "build:transform": "node --check ./transform/index.mjs",
    "test:wasmtime": "wasmtime ./build/test.wasm",
    "bench:mode-compare:i8x8": "bun ./scripts/chart-i8x8-swar-v-i8x8-simd.ts",
    "bench:compare:v128": "bun ./scripts/chart-v128-swar-v-v128-simd.ts",
    "bench:compare:v64-v128": "bun ./scripts/chart-v64-swar-v-v128-simd.ts",
    "format": "prettier -w .",
    "charts": "npm run charts:build && npm run charts:serve",
    "charts:build": "./scripts/build-charts.sh",
    "charts:serve": "serve ./charts"
  },
  "devDependencies": {
    "@assemblyscript/wasi-shim": "^0.1.0",
    "@types/node": "^25.6.0",
    "as-bench": "^0.0.0-alpha",
    "as-test": "1.0.11",
    "assemblyscript": "^0.28.14",
    "assemblyscript-prettier": "^3.0.4",
    "json-as": "^1.3.2",
    "serve": "^14.2.6"
  },
  "overrides": {
    "assemblyscript": "$assemblyscript"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JairusSW/as-simd.git"
  },
  "keywords": [
    "assemblyscript",
    "SIMD",
    "SSE",
    "AVX"
  ],
  "bugs": {
    "url": "https://github.com/JairusSW/as-simd/issues"
  },
  "homepage": "https://github.com/JairusSW/as-simd#readme",
  "type": "module",
  "publishConfig": {
    "@JairusSW:registry": "https://npm.pkg.github.com"
  }
}
