{
  "$schema": "node_modules/as-test/as-test.config.schema.json",
  "input": [
    "assembly/__tests__/*.spec.ts"
  ],
  "output": ".as-test/",
  "config": "none",
  "coverage": false,
  "env": {},
  "buildOptions": {
    "target": "bindings"
  },
  "runOptions": {
    "runtime": {
      "cmd": "node .as-test/runners/default.bindings.js <file>"
    },
    "reporter": "default"
  },
  "modes": {}
}
