{
  "$schema": "./node_modules/as-test/as-test.config.schema.json",
  "input": ["./assembly/__tests__/*.spec.ts"],
  "coverage": true,
  "buildOptions": {
    "target": "bindings",
    "args": ["--enable", "sign-extension"]
  },
  "fuzz": {
    "input": ["./assembly/__fuzz__/*.fuzz.ts"],
    "runs": 10000000,
    "target": "bindings"
  },
  "runOptions": { "reporter": "default" },
  "modes": {
    "swar": {
      "coverage": false,
      "buildOptions": {
        "args": ["--transform", "./transform/index.mjs"]
      }
    },
    "simd": {
      "buildOptions": {
        "args": ["--enable simd", "--enable relaxed-simd"]
      }
    }
  }
}
