{
  "$schema": "./node_modules/as-test/as-test.config.schema.json",
  "input": ["./assembly/__tests__/*.spec.ts"],
  "buildOptions": {
    "target": "bindings",
    "args": ["--enable", "sign-extension"]
  },
  "fuzz": {
    "input": ["./assembly/__fuzz__/*.fuzz.ts"],
    "runs": 1000000,
    "seed": 1337,
    "target": "bindings"
  },
  "runOptions": { "reporter": "default" },
  "modes": {
    "swar": {
      "env": {
        "JSON_MODE": "SWAR"
      }
    },
    "simd": {
      "env": {
        "JSON_MODE": "SIMD"
      },
      "buildOptions": {
        "args": ["--enable simd", "--enable", "sign-extension"]
      }
    }
  }
}
